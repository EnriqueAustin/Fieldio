# ----- Core -----
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fieldio
JWT_SECRET=CHANGE-ME-generate-a-64-char-random-secret-openssl-rand-hex-32
JWT_REFRESH_SECRET=CHANGE-ME-generate-a-64-char-refresh-secret-openssl-rand-hex32
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ----- Stripe (payments) -----
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# After running `stripe listen --forward-to localhost:3001/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=

# ----- Email (Resend) -----
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM="Fieldio <noreply@yourdomain.com>"

# ----- SMS (Twilio) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555

# ----- Object storage (S3 or Cloudflare R2) -----
# For R2: set S3_ENDPOINT to https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ----- Maps -----
MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_TOKEN=

# ----- Web app -----
NEXT_PUBLIC_API_URL=http://localhost:3001
