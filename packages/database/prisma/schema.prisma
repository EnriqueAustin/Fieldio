// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Core Entities
// -----------------------------------------------------------------------------

model Company {
  id        String   @id @default(uuid())
  name      String
  settings  Json?    // Branding, Modules, Localization
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  customers     Customer[]
  jobs          Job[]
  estimates     Estimate[]
  invoices      Invoice[]
  inventory     InventoryItem[]
  notifications Notification[]
  auditLogs     AuditLog[]
  properties    Property[]
  expenses      Expense[]
  payments      Payment[]
  jobPhotos     JobPhoto[]
  notificationLogs NotificationLog[]
  recurringPlans RecurringPlan[]
  bookingRequests BookingRequest[]
  xeroConnections XeroConnection[]
  priceBookItems  PriceBookItem[]
  suppliers       Supplier[]
  purchaseOrders  PurchaseOrder[]
}

enum UserRole {
  ADMIN
  DISPATCHER
  OFFICE
  TECHNICIAN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

model User {
  id           String     @id @default(uuid())
  companyId    String
  email        String     @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         UserRole   @default(TECHNICIAN)
  permissions  Json?      // Specific capabilities e.g., 'job:read'
  avatarUrl    String?
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  company      Company    @relation(fields: [companyId], references: [id])
  assignedJobs Job[]
  notifications Notification[]
  auditLogs    AuditLog[]
  locationPings UserLocationPing[]

  @@index([companyId])
}

model UserLocationPing {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  lat       Float
  lng       Float
  accuracy  Float?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([companyId])
}

// -----------------------------------------------------------------------------
// CRM
// -----------------------------------------------------------------------------

enum CustomerStatus {
  ACTIVE
  LEAD
  ARCHIVED
}

model Customer {
  id        String         @id @default(uuid())
  companyId String
  name      String
  email     String?
  phone     String?
  notes     String?
  status    CustomerStatus @default(ACTIVE)
  deletedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  company    Company    @relation(fields: [companyId], references: [id])
  properties Property[]
  jobs       Job[]
  estimates  Estimate[]
  bookingRequests BookingRequest[]
  portalTokens CustomerPortalToken[]

  @@index([companyId])
}

model Property {
  id           String @id @default(uuid())
  customerId   String
  companyId    String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zip          String
  geoLat       Float?
  geoLng       Float?

  customer Customer @relation(fields: [customerId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  jobs     Job[]
  assets   PropertyAsset[]

  @@index([companyId])
  @@index([customerId])
}

enum AssetStatus {
  ACTIVE
  NEEDS_SERVICE
  RETIRED
}

model PropertyAsset {
  id             String      @id @default(uuid())
  propertyId     String
  companyId      String
  name           String
  category       String?
  manufacturer   String?
  model          String?
  serialNumber   String?
  installedAt    DateTime?
  lastServicedAt DateTime?
  warrantyUntil  DateTime?
  notes          String?
  status         AssetStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([companyId])
  @@index([propertyId])
}

// -----------------------------------------------------------------------------
// Work Management
// -----------------------------------------------------------------------------

enum JobStatus {
  REQUESTED
  ASSIGNED
  EN_ROUTE
  ON_SITE
  COMPLETED
  CANCELED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

model Job {
  id             String      @id @default(uuid())
  companyId      String
  customerId     String
  propertyId     String
  techId         String?
  status         JobStatus   @default(REQUESTED)
  priority       JobPriority @default(MEDIUM)
  title          String
  description    String?
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  recurringPlanId String?
  deletedAt      DateTime?
  reviewRequestSentAt DateTime?
  company   Company        @relation(fields: [companyId], references: [id])
  customer  Customer       @relation(fields: [customerId], references: [id])
  property  Property       @relation(fields: [propertyId], references: [id])
  tech      User?          @relation(fields: [techId], references: [id])
  lineItems JobLineItem[]
  checklist JobChecklist[]
  estimate  Estimate?
  invoice   Invoice?
  expenses  Expense[]
  photos    JobPhoto[]
  signatures JobSignature[]
  recurringPlan RecurringPlan? @relation(fields: [recurringPlanId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
  @@index([techId])
  @@index([status])
  @@index([recurringPlanId])
}

model JobPhoto {
  id        String   @id @default(uuid())
  jobId     String
  companyId String
  url       String
  thumbnailUrl String?
  caption   String?
  uploadedById String?
  createdAt DateTime @default(now())

  job     Job     @relation(fields: [jobId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([jobId])
  @@index([companyId])
}

model JobSignature {
  id        String   @id @default(uuid())
  jobId     String
  signerName String
  signatureDataUrl String?
  signatureUrl     String?
  signedAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

enum LineItemType {
  SERVICE
  MATERIAL
  LABOR
}

model JobLineItem {
  id          String       @id @default(uuid())
  jobId       String
  name        String
  description String?
  quantity    Float
  unitPrice   Decimal
  total       Decimal
  type        LineItemType @default(SERVICE)

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model JobChecklist {
  id          String   @id @default(uuid())
  jobId       String
  label       String
  isCompleted Boolean  @default(false)
  completedAt DateTime?

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

// -----------------------------------------------------------------------------
// Finance
// -----------------------------------------------------------------------------

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
}

model Estimate {
  id         String         @id @default(uuid())
  companyId  String
  customerId String
  jobId      String?        @unique
  status     EstimateStatus @default(DRAFT)
  items      Json           // Snapshot of line items
  total      Decimal
  validUntil DateTime?
  pdfUrl     String?
  signerName String?
  signatureUrl String?
  signedAt   DateTime?
  approvedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  job      Job?     @relation(fields: [jobId], references: [id])

  @@index([companyId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  VOID
}

model Invoice {
  id              String        @id @default(uuid())
  companyId       String
  jobId           String        @unique
  invoiceNumber   String?
  status          InvoiceStatus @default(DRAFT)
  items           Json?         // Snapshot of line items at time of invoice
  subtotal        Decimal
  tax             Decimal
  total           Decimal
  balance         Decimal
  taxLabel        String        @default("VAT")
  taxRate         Decimal       @default(15)
  taxNumber       String?
  supplierName    String?
  supplierCompanyRegistration String?
  paymentReference String?
  dueDate         DateTime?
  stripePaymentId String?
  stripeCheckoutSessionId String?
  publicToken     String?       @unique
  paidAt          DateTime?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  job      Job       @relation(fields: [jobId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@unique([companyId, invoiceNumber])
}

enum PaymentMethod {
  CARD
  ACH
  CASH
  CHECK
  EFT
  PAYFAST
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id        String        @id @default(uuid())
  companyId String
  invoiceId String
  amount    Decimal
  method    PaymentMethod @default(CARD)
  status    PaymentStatus @default(PENDING)
  stripePaymentIntentId String? @unique
  stripeChargeId String?
  failureReason String?
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([companyId])
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  SYNC_ERROR
}

model XeroConnection {
  id           String            @id @default(uuid())
  companyId    String
  tenantId     String
  tenantName   String?
  status       IntegrationStatus @default(CONNECTED)
  lastSyncedAt DateTime?
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, tenantId])
  @@index([companyId])
}

// -----------------------------------------------------------------------------
// Operations
// -----------------------------------------------------------------------------

enum InventoryLocation {
  WAREHOUSE
  VAN
}

model InventoryItem {
  id             String            @id @default(uuid())
  companyId      String
  name           String
  sku            String?
  quantity       Int
  minLevel       Int               @default(5)
  location       InventoryLocation @default(WAREHOUSE)
  assignedUserId String?

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

enum NotificationType {
  SYSTEM
  JOB_ASSIGNED
  MENTION
  ALERT
}

model Notification {
  id        String           @id @default(uuid())
  companyId String
  userId    String
  type      NotificationType
  title     String
  message   String
  readAt    DateTime?
  createdAt DateTime         @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  companyId String
  userId    String
  action    String
  entityId  String
  entityType String
  metadata  Json?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([entityId])
}

model Expense {
  id          String   @id @default(uuid())
  companyId   String
  jobId       String
  description String
  amount      Decimal
  receiptUrl  String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  job     Job     @relation(fields: [jobId], references: [id])

  @@index([companyId])
  @@index([jobId])
}

// -----------------------------------------------------------------------------
// Notifications log (delivery tracking for email/SMS)
// -----------------------------------------------------------------------------

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationDeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model NotificationLog {
  id        String                     @id @default(uuid())
  companyId String
  channel   NotificationChannel
  toAddress String
  template  String
  payload   Json?
  status    NotificationDeliveryStatus @default(QUEUED)
  providerId String?
  error     String?
  createdAt DateTime                   @default(now())
  updatedAt DateTime                   @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId, createdAt])
}

// -----------------------------------------------------------------------------
// Recurring service plans (maintenance contracts)
// -----------------------------------------------------------------------------

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model RecurringPlan {
  id          String             @id @default(uuid())
  companyId   String
  customerId  String
  propertyId  String
  title       String
  description String?
  frequency   RecurringFrequency
  startDate   DateTime
  endDate     DateTime?
  nextRunAt   DateTime
  active      Boolean            @default(true)
  template    Json?              // line items snapshot
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id])
  jobs    Job[]

  @@index([companyId])
  @@index([nextRunAt, active])
}

// -----------------------------------------------------------------------------
// Public customer booking requests
// -----------------------------------------------------------------------------

enum BookingStatus {
  NEW
  CONTACTED
  CONVERTED
  REJECTED
}

model BookingRequest {
  id          String        @id @default(uuid())
  companyId   String
  customerId  String?
  name        String
  email       String?
  phone       String?
  addressLine1 String?
  city         String?
  state        String?
  zip          String?
  serviceType String?
  description String
  preferredDate DateTime?
  status      BookingStatus @default(NEW)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company  Company   @relation(fields: [companyId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([companyId, status])
}

// -----------------------------------------------------------------------------
// Price Book
// -----------------------------------------------------------------------------

model PriceBookItem {
  id          String       @id @default(uuid())
  companyId   String
  name        String
  description String?
  unitPrice   Decimal
  type        LineItemType @default(SERVICE)
  category    String?
  sku         String?
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// -----------------------------------------------------------------------------
// Suppliers & Purchase Orders
// -----------------------------------------------------------------------------

model Supplier {
  id             String   @id @default(uuid())
  companyId      String
  name           String
  contactName    String?
  email          String?
  phone          String?
  accountNumber  String?
  notes          String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  PARTIAL
  CANCELED
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  companyId    String
  supplierId   String
  jobId        String?
  orderNumber  String?
  status       PurchaseOrderStatus @default(DRAFT)
  items        Json
  subtotal     Decimal
  tax          Decimal             @default(0)
  total        Decimal
  notes        String?
  expectedDate DateTime?
  receivedAt   DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  company  Company  @relation(fields: [companyId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  job      Job?     @relation(fields: [jobId], references: [id])

  @@index([companyId])
  @@index([supplierId])
  @@index([jobId])
  @@unique([companyId, orderNumber])
}

// -----------------------------------------------------------------------------
// Customer Self-Service Portal
// -----------------------------------------------------------------------------

model CustomerPortalToken {
  id         String   @id @default(uuid())
  companyId  String
  customerId String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([token])
  @@index([customerId])
}
