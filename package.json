{
  "name": "fieldio",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "infra:up": "docker compose up -d postgres redis adminer",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:migrate": "npm run db:migrate --workspace=@fieldio/database",
    "db:seed": "npm run db:seed --workspace=@fieldio/database",
    "setup": "npm install && npm run db:migrate && npm run db:seed",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@10.2.4",
  "engines": {
    "node": ">=18"
  }
}
